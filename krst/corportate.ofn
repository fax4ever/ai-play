ClassAssertion(:HRDepartment :HRDepartment_Ind)
DataPropertyAssertion(:departmentCode :HRDepartment_Ind "HR-001")

# Individual: :ITDepartment (:ITDepartment)

ClassAssertion(:TechnicalDepartment :ITDepartment)
ObjectPropertyAssertion(:hasCEO :ITDepartment :JohnSmith)
ObjectPropertyAssertion(:locatedIn :ITDepartment :MainBuilding)
DataPropertyAssertion(:departmentCode :ITDepartment "IT-001")

