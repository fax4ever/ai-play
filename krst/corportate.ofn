ClassAssertion(:Employee :EveWhite)

# Individual: :FrankMiller (:FrankMiller)

ClassAssertion(:Manager :FrankMiller)
ObjectPropertyAssertion(:leadsProject :FrankMiller :ProjectAlpha)
ObjectPropertyAssertion(:manages :FrankMiller :ProjectAlpha)

