Prefix(xsd:=<http://www.w3.org/2001/XMLSchema#>)
Prefix(rdfs:=<http://www.w3.org/2000/01/rdf-schema#>)


Ontology(<http://www.semanticweb.org/fax/ontologies/2026/corporate>
<http://www.semanticweb.org/fax/ontologies/2026/corporate/1.0.0>

